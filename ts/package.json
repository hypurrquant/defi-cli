      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "vite": ">=7.3.2",
      "postcss": ">=8.5.10",
      "hono": ">=4.12.18",
      "@hono/node-server": ">=1.19.13",
